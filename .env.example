# ─────────────────────────────────────────────────────────────────────────
# Copia este archivo a  .env  y rellena los valores. .env está en .gitignore.
# En Vercel, estas mismas variables se cargan en Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────

# Connection string de Neon (Postgres). La obtienes en el dashboard de Neon:
#   Project → Connection Details → "Connection string" (con ?sslmode=require).
DATABASE_URL="postgresql://usuario:password@ep-xxxx.sa-east-1.aws.neon.tech/vetlain?sslmode=require"

# Secreto para firmar los tokens de sesión del panel de administración.
# Usa un valor largo y aleatorio (p. ej. `openssl rand -base64 48`).
JWT_SECRET="reemplaza-esto-por-un-secreto-largo-y-aleatorio"

# Token para el endpoint de arranque GET /api/setup?token=... (crea tablas +
# carga inicial). Ponlo en Vercel, visita la URL una vez, y luego BÓRRALO.
SETUP_TOKEN="otro-valor-largo-y-aleatorio-distinto-al-jwt"

# Credenciales del primer administrador que crea el seed. Cámbialas por las del
# cliente. Tras el primer login conviene cambiar la contraseña.
ADMIN_EMAIL="admin@vetlain.cl"
ADMIN_PASSWORD="cambia-esta-contrasena"

# Dominio canónico del sitio (sitemap, robots, canonical). Por defecto
# https://vetlain.cl. Para el frontend, la variable equivalente es VITE_SITE_URL.
SITE_URL="https://vetlain.cl"

# Deploy Hook de Vercel (Project Settings → Git → Deploy Hooks → crear uno,
# rama main). Lo usa el botón "Publicar cambios" del panel para disparar un
# rebuild (que regenera el HTML estático de las páginas/servicios/blog).
DEPLOY_HOOK_URL="https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy"

# Puerto del servidor Express en desarrollo local (no aplica en Vercel).
# 8787 elegido para no chocar con otros proyectos (Next.js suele usar 3000/3001).
PORT=8787
