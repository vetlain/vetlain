# ─────────────────────────────────────────────────────────────────────────
# Copia este archivo a  .env  y rellena los valores. .env está en .gitignore.
# En Vercel, estas mismas variables se cargan en Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────

# Connection string de Neon (Postgres). La obtienes en el dashboard de Neon:
#   Project → Connection Details → "Connection string" (con ?sslmode=require).
DATABASE_URL="postgresql://usuario:password@ep-xxxx.sa-east-1.aws.neon.tech/vetlain?sslmode=require"

# Secreto para firmar los tokens de sesión del panel de administración.
# Usa un valor largo y aleatorio (p. ej. `openssl rand -base64 48`).
JWT_SECRET="reemplaza-esto-por-un-secreto-largo-y-aleatorio"

# Puerto del servidor Express en desarrollo local (no aplica en Vercel).
# 8787 elegido para no chocar con otros proyectos (Next.js suele usar 3000/3001).
PORT=8787
